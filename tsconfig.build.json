  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "sourceMap": true,
    "noEmit": false
  },
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["coverage", "dist", "node_modules", "test/**/*.ts", "test/**/*.tsx", "vitest.config.ts"]
}
