{
  "name": "archa",
  "version": "0.1.0",
  "description": "Your personal code archaeologist for repo-aware engineering Q&A",
  "type": "module",
  "bin": {
    "archa": "./dist/bin/archa.js",
    "archa-server": "./dist/bin/archa-server.js"
  },
  "exports": {},
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "postbuild": "node ./scripts/ensure-bin-executable.mjs",
    "typecheck": "tsc -p tsconfig.json && tsc -p tsconfig.test.json",
    "check": "npm run typecheck && npm test && npm run build",
    "prepack": "npm run build",
    "cli": "node --import tsx src/bin/archa.ts",
    "server": "node --import tsx src/bin/archa-server.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=24"
  }
}
